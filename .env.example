# research-hub Environment Variables
DJANGO_SETTINGS_MODULE=config.settings.base
SECRET_KEY=change-me-in-production
DEBUG=False
ALLOWED_HOSTS=research.iil.pet,localhost

# Database
DATABASE_URL=postgresql://research_hub:research_hub@db:5432/research_hub

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# iil-researchfw
BRAVE_API_KEY=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587

# Sentry (optional)
SENTRY_DSN=
